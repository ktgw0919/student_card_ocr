# API / PII（Phase 1–2）
DEBUG_MODE=false
ALLOW_INCLUDE_RAW=false
INCLUDE_RAW_DEFAULT=false
INCLUDE_SOURCE_TEXT_DEFAULT=false
MAX_UPLOAD_BYTES=10485760

# 運用（Phase 3）
# カンマ区切り。空なら CORS 無効
CORS_ORIGINS=
REQUIRE_API_KEY=false
API_KEY=
# 0 でレート制限無効
RATE_LIMIT_PER_MINUTE=30

# ローカル開発の例（フェーズ1 Web UI は同一オリジンで / を開く）:
# RATE_LIMIT_PER_MINUTE=0
# DEBUG_MODE=true
# CORS_ORIGINS=http://localhost:3000
# ALLOW_INCLUDE_RAW=true
# REQUIRE_API_KEY=true
# API_KEY=dev-local-key
